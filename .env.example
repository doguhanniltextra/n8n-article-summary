# n8n webhook endpoint
# Use /webhook-test/ for testing, /webhook/ for production
N8N_ENDPOINT=http://localhost:5678/webhook/article-summary

# Go web app port
APP_PORT=8090

# Obsidian Local REST API (optional)
# Get this from Obsidian → Settings → Local REST API → API Key
OBSIDIAN_API_KEY=your-api-key-here
OBSIDIAN_PORT=27123

# LM Studio
LM_STUDIO_URL=http://localhost:1234
LM_STUDIO_MODEL=mistral-7b-instruct-v0.2
